{
  "version": 2,
  "builds": [
    {
      "src": "api/contact.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/contact",
      "dest": "/api/contact.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
